multiple website with navigation


<!DOCTYPE html>
<html>
<head>
<title>Multi Page Website</title>
<style> body{
margin:0;
font-family:Arial, sans-serif; background:#f4f4f4;
}

.navbar{ background:#333; padding:15px; text-align:center; position:sticky; top:0;
}

.navbar a{ color:white;
text-decoration:none; margin:20px;
font-size:18px; font-weight:bold;
}

.navbar a:hover{ color:yellow;
}

.section{ padding:80px; text-align:center; height:100vh;
}

#home{ background:#e8f0ff; } #about{ background:#ffe8e8; } #contact{ background:#e8ffe8; }
</style>

</head>
<body>

<div class="navbar">
 
<a href="#home">Home</a>
<a href="#about">About</a>
<a href="#contact">Contact</a>
</div>

<div id="home" class="section">
<h1>Welcome to My Website</h1>
<p>This is Home Section</p>
</div>
<div id="about" class="section">
<h1>About Us</h1>
<p>This website is developed using HTML and CSS.</p>
</div>

<div id="contact" class="section">
<h1>Contact Us</h1>
<p>Email : example@gmail.com</p>
</div>

</body>  
